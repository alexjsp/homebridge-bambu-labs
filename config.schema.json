{
  "pluginAlias": "BambuLabs",
  "pluginType": "platform",
  "singular": true,
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Name",
        "type": "string",
        "default": "Bambu Labs"
      },
      "cloudMode": {
        "title": "Cloud Mode",
        "description": "Connect to printers via Bambu Labs cloud instead of LAN",
        "type": "boolean",
        "default": false
      },
      "cloudEmail": {
        "title": "Bambu Labs Email",
        "description": "Your Bambu Labs account email (cloud mode only)",
        "type": "string",
        "condition": { "functionBody": "return model.cloudMode === true;" }
      },
      "cloudPassword": {
        "title": "Bambu Labs Password",
        "description": "Your Bambu Labs account password (cloud mode only)",
        "type": "string",
        "condition": { "functionBody": "return model.cloudMode === true;" }
      },
      "cloudToken": {
        "title": "Auth Token",
        "description": "Bambu Labs auth token (alternative to email/password, e.g. if 2FA is enabled)",
        "type": "string",
        "condition": { "functionBody": "return model.cloudMode === true;" }
      },
      "cloudRegion": {
        "title": "Cloud Region",
        "description": "Bambu Labs cloud region",
        "type": "string",
        "default": "global",
        "oneOf": [
          { "title": "Global", "enum": ["global"] },
          { "title": "China", "enum": ["china"] }
        ],
        "condition": { "functionBody": "return model.cloudMode === true;" }
      },
      "printers": {
        "title": "Printers",
        "description": "In cloud mode without printers listed, all printers on your account are auto-discovered",
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "title": "Printer Name",
              "type": "string",
              "required": true
            },
            "ip": {
              "title": "IP Address",
              "type": "string",
              "description": "Required for LAN mode",
              "condition": { "functionBody": "return !model.cloudMode;" }
            },
            "serial": {
              "title": "Serial Number",
              "type": "string",
              "required": true
            },
            "accessCode": {
              "title": "Access Code",
              "type": "string",
              "description": "Required for LAN mode",
              "condition": { "functionBody": "return !model.cloudMode;" }
            },
            "enableNozzleTemperature": {
              "title": "Enable Nozzle Temperature Sensor",
              "type": "boolean",
              "default": true
            },
            "enableBedTemperature": {
              "title": "Enable Bed Temperature Sensor",
              "type": "boolean",
              "default": true
            },
            "enableChamberTemperature": {
              "title": "Enable Chamber Temperature Sensor",
              "type": "boolean",
              "default": true
            }
          }
        }
      }
    }
  }
}
